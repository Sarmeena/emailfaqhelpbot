rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user document data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper functions for roles
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isAgent() {
      return isAuthenticated() && (getUserData().role == 'agent' || getUserData().role == 'admin');
    }
    
    function isViewer() {
      return isAuthenticated() && (getUserData().role == 'viewer' || getUserData().role == 'agent' || getUserData().role == 'admin');
    }

    // --- Users Collection ---
    // User documents are stored at users/{userId} where userId is the user's UID
    match /users/{userId} {
      // Users can read only their own profile document, unless they are an admin
      allow read: if isAuthenticated() && (request.auth.uid == userId || getUserData().role == 'admin');
      
      // Users can create their own profile document on registration
      // The default role must always be 'viewer', or 'admin' only for the system backend
      allow create: if isAuthenticated() && request.auth.uid == userId && (
        request.resource.data.role == 'viewer' ||
        (request.resource.data.role == 'admin' && request.auth.token.email == 'system-backend@emailfaqhelpbot.com')
      );
      
      // Users can update their own profile document, but they cannot change their role.
      // Only admins can change a user's role.
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );
      
      // Only admins can delete user documents
      allow delete: if isAdmin();
    }

    // --- FAQs Collection ---
    // Public FAQ portal needs to read FAQs, so read is public (allow read: if true)
    // Writes (create, update, delete) are restricted to agents and admins
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAgent();
    }

    // --- Requests Collection ---
    // Authenticated users (admin, agent, viewer) can read customer requests
    // Writes are restricted to agents and admins
    match /requests/{requestId} {
      allow read: if isViewer();
      allow write: if isAgent();
    }

    // --- Conversations Collection ---
    // Authenticated users can read conversations
    // Writes are restricted to agents and admins
    match /conversations/{conversationId} {
      allow read: if isViewer();
      allow write: if isAgent();
    }

    // --- Messages Collection ---
    // Messages in conversations
    match /messages/{messageId} {
      allow read: if isViewer();
      allow write: if isAgent();
    }

    // --- Broadcasts Collection ---
    // Marketing campaign broadcasts
    match /broadcasts/{broadcastId} {
      allow read: if isViewer(); // Read-only for stats and listing
      allow write: if isAgent();
    }

    // --- Settings Collection ---
    // Contains configuration documents like settings/gemini and settings/gmail
    // Restricted strictly to admins
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
